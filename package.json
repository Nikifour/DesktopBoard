{
  "name": "desktop-board",
  "version": "0.1.0",
  "description": "A Windows desktop board for notes, schedule blocks, and quick personal widgets.",
  "author": "Desktop Board",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "preview": "node scripts/serve.js",
    "check": "node --check main.js && node --check preload.js && node --check src/renderer.js && node --check scripts/serve.js",
    "dist": "electron-builder",
    "dist:win": "set ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/&& set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win",
    "dist:win:publish": "set ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/&& set CSC_IDENTITY_AUTO_DISCOVERY=false&& electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.desktopboard.app",
    "productName": "Desktop Board",
    "electronVersion": "41.2.1",
    "electronDist": "node_modules/electron/dist",
    "electronUpdaterCompatibility": ">=2.16",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Nikifour",
        "repo": "DesktopBoard",
        "releaseType": "draft"
      }
    ],
    "win": {
      "icon": "src/assets/app-icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "src/assets/app-icon.ico",
      "uninstallerIcon": "src/assets/app-icon.ico",
      "installerHeaderIcon": "src/assets/app-icon.ico",
      "shortcutName": "Desktop Board"
    }
  },
  "devDependencies": {
    "electron": "41.2.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "6.8.3",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "xlsx": "^0.18.5"
  }
}
